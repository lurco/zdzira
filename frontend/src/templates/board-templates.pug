script#tmpl-board(type="text/x-handlebars-template")
  | {{#each swimlanes}}
  |   <div class="lane" data-lane-id="{{id}}" data-lane-name="{{name}}">
  |     <div class="lane-header">
  |       <span class="lane-swatch" style="background:{{laneColor color}}"></span>
  |       <input class="lane-title" name="name" value="{{name}}" maxlength="40"
  |              hx-patch="/api/v1/projects/{{projectSlug}}/swimlanes/{{id}}"
  |              hx-trigger="blur changed"
  |              hx-ext="json-enc"
  |              hx-include="this"
  |              hx-swap="none">
  |       <span class="lane-count">{{issues.length}}</span>
  |       <button class="lane-menu" type="button" data-lane-menu="{{id}}" aria-label="Lane menu">⋯</button>
  |     </div>
  |     <div class="popover" data-lane-popover="{{id}}" hidden>
  |       <div class="popover__swatches">
  |         {{#each (laneColors)}}
  |           <button class="popover__swatch" type="button" style="background:{{this}}"
  |                   hx-patch="/api/v1/projects/{{projectSlug}}/swimlanes/{{../id}}"
  |                   hx-ext="json-enc"
  |                   hx-vals='{"color":"{{this}}"}'
  |                   hx-swap="none"></button>
  |         {{/each}}
  |       </div>
  |       <button class="popover__btn popover__danger" type="button"
  |               data-dialog-open="tmpl-confirm-delete-lane"
  |               data-dialog-data='{"laneId":{{id}},"laneName":"{{name}}"}'>
  |         Delete lane
  |       </button>
  |     </div>
  |     <div class="lane-body" data-lane-id="{{id}}">
  |       {{#if issues.length}}
  |         {{#each issues}}
  |           <div class="card" draggable="true" data-drag-kind="card" data-card-ref="{{ref}}" data-lane-id="{{swimlane_id}}"
  |                hx-get="/api/v1/projects/{{projectSlug}}/issues/{{ref}}"
  |                hx-target="#issuePanel"
  |                hx-trigger="click"
  |                hx-push-url="/board.html?project={{projectSlug}}&issue={{ref}}">
  |             <div class="card-strip" style="background:{{laneColor ../color}}"></div>
  |             <div class="card-top">
  |               <span class="card-id mono">{{ref}}</span>
  |               <span class="badge {{priorityClass priority}}">{{priority}}</span>
  |             </div>
  |             <div class="card-title">{{name}}</div>
  |             <div class="card-meta">
  |               <span class="tag tag-{{lower type}}">{{type}}</span>
  |               {{#if epic_ref}}
  |                 <span class="card-epic" title="{{epic_name}}">{{epic_ref}}</span>
  |               {{/if}}
  |             </div>
  |           </div>
  |         {{/each}}
  |       {{else}}
  |         <div class="lane-empty">No issues</div>
  |       {{/if}}
  |     </div>
  |     <div class="lane-footer">
  |       <button class="add-card-btn" type="button" data-lane-id="{{id}}">+ Add issue</button>
  |     </div>
  |   </div>
  | {{/each}}
  | <button class="add-lane" type="button"
  |         hx-post="/api/v1/projects/{{projectSlug}}/swimlanes"
  |         hx-ext="json-enc"
  |         hx-vals='{"name":"New lane"}'
  |         hx-swap="none">
  |   <span class="plus">+</span> Add lane
  | </button>

script#tmpl-epic-options(type="text/x-handlebars-template")
  | <option value="">All issues</option>
  | {{#each this}}
  |   <option value="{{ref}}" {{selectedIfCurrentEpic ref}}>{{ref}} — {{name}}</option>
  | {{/each}}

script#tmpl-epics-manager(type="text/x-handlebars-template")
  | <div class="modal__form epics-manager" data-dialog-keep-open>
  |   <h2 class="modal__title">Epics</h2>
  |   {{#if epics.length}}
  |     <ul class="epics-manager__list">
  |       {{#each epics}}
  |         <li class="epics-manager__row">
  |           <span class="epics-manager__ref mono">{{ref}}</span>
  |           <span class="epics-manager__name">{{name}}</span>
  |           <button class="btn ghost epics-manager__edit"
  |                   type="button"
  |                   data-open-epic-edit
  |                   data-epic-ref="{{ref}}"
  |                   data-epic-name="{{name}}"
  |                   data-epic-description="{{description}}">Edit</button>
  |           <button class="btn ghost epics-manager__delete"
  |                   type="button"
  |                   hx-delete="/api/v1/projects/{{../projectSlug}}/epics/{{ref}}"
  |                   hx-swap="none">Delete</button>
  |         </li>
  |       {{/each}}
  |     </ul>
  |   {{else}}
  |     <p class="modal__hint">No epics yet.</p>
  |   {{/if}}
  |   <form class="epics-manager__form"
  |         hx-post="/api/v1/projects/{{projectSlug}}/epics"
  |         hx-ext="json-enc"
  |         hx-swap="none">
  |     <label class="modal__label">New epic</label>
  |     <input class="modal__input" name="name" placeholder="Epic name" required>
  |     <label class="modal__label">Description</label>
  |     <textarea class="modal__input modal__input--multiline" name="description" rows="2" placeholder="Optional description"></textarea>
  |     <div class="modal__actions">
  |       <button class="modal__btn modal__btn--cancel" type="button" data-dialog-close>Close</button>
  |       <button class="modal__btn modal__btn--submit" type="submit">Add epic</button>
  |     </div>
  |   </form>
  | </div>

script#tmpl-epic-edit(type="text/x-handlebars-template")
  | <form class="modal__form"
  |       hx-put="/api/v1/projects/{{projectSlug}}/epics/{{ref}}"
  |       hx-ext="json-enc"
  |       hx-swap="none">
  |   <h2 class="modal__title">Edit {{ref}}</h2>
  |   <label class="modal__label">Name</label>
  |   <input class="modal__input" name="name" value="{{name}}" required autofocus>
  |   <label class="modal__label">Description</label>
  |   <textarea class="modal__input modal__input--multiline" name="description" rows="4">{{description}}</textarea>
  |   <div class="modal__actions">
  |     <button class="modal__btn modal__btn--cancel" type="button" data-dialog-close>Cancel</button>
  |     <button class="modal__btn modal__btn--submit" type="submit">Save</button>
  |   </div>
  | </form>

script#tmpl-add-issue-form(type="text/x-handlebars-template")
  | <form class="modal__form"
  |       hx-post="/api/v1/projects/{{projectSlug}}/issues"
  |       hx-ext="json-enc"
  |       hx-vals='{"swimlane_id": {{laneId}}}'
  |       hx-swap="none">
  |   <h2 class="modal__title">New issue in {{laneName}}</h2>
  |   <label class="modal__label">Title</label>
  |   <input class="modal__input" name="name" placeholder="What needs doing?" required autofocus>
  |   <label class="modal__label">Description</label>
  |   <textarea class="modal__input modal__input--multiline" name="description" rows="3"></textarea>
  |   <div class="modal__row">
  |     <label class="modal__label modal__label--inline">Type</label>
  |     <select class="modal__select" name="type">
  |       <option value="TASK" selected>Task</option>
  |       <option value="BUG">Bug</option>
  |       <option value="STORY">Story</option>
  |     </select>
  |     <label class="modal__label modal__label--inline">Priority</label>
  |     <select class="modal__select" name="priority">
  |       <option value="LOW" selected>Low</option>
  |       <option value="HIGH">High</option>
  |       <option value="IMMEDIATE">Immediate</option>
  |     </select>
  |   </div>
  |   {{#if epics.length}}
  |     <label class="modal__label">Epic</label>
  |     <select class="modal__select" name="epic_ref">
  |       <option value="">No epic</option>
  |       {{#each epics}}
  |         <option value="{{ref}}">{{ref}} — {{name}}</option>
  |       {{/each}}
  |     </select>
  |   {{/if}}
  |   <div class="modal__actions">
  |     <button class="modal__btn modal__btn--cancel" type="button" data-dialog-close>Cancel</button>
  |     <button class="modal__btn modal__btn--submit" type="submit">Add issue</button>
  |   </div>
  | </form>

script#tmpl-issue-panel(type="text/x-handlebars-template")
  | <div class="issue-panel__inner">
  |   <header class="issue-panel__header">
  |     <span class="issue-panel__ref mono">{{ref}}</span>
  |     <span class="badge {{priorityClass priority}}">{{priority}}</span>
  |     <span class="tag tag-{{lower type}}">{{type}}</span>
  |     <button type="button" class="btn ghost" data-issue-edit>Edit</button>
  |     <button type="button" class="btn ghost"
  |             data-dialog-open="tmpl-confirm-delete-issue"
  |             data-dialog-data='{"ref":"{{ref}}","name":"{{name}}"}'>Delete</button>
  |     <button type="button" class="issue-panel__close" data-issue-panel-close aria-label="Close">×</button>
  |   </header>
  |   <h2 class="issue-panel__title">{{name}}</h2>
  |   {{#if epic_ref}}
  |     <div class="issue-panel__epic">
  |       <span class="issue-panel__epic-label">Epic</span>
  |       <span class="issue-panel__epic-ref">{{epic_ref}}</span>
  |       <span class="issue-panel__epic-name">{{epic_name}}</span>
  |     </div>
  |   {{/if}}
  |   {{#if description}}
  |     <div class="issue-panel__description">{{description}}</div>
  |   {{/if}}
  | </div>

script#tmpl-issue-edit-form(type="text/x-handlebars-template")
  | <form class="issue-panel__inner"
  |       hx-put="/api/v1/projects/{{projectSlug}}/issues/{{ref}}"
  |       hx-ext="json-enc"
  |       hx-target="#issuePanel"
  |       hx-swap="innerHTML">
  |   <header class="issue-panel__header">
  |     <span class="issue-panel__ref mono">{{ref}}</span>
  |     <span class="issue-panel__spacer"></span>
  |     <button type="submit" class="btn primary">Save</button>
  |     <button type="button" class="btn ghost" data-issue-edit-cancel>Cancel</button>
  |   </header>
  |   <label class="modal__label">Title</label>
  |   <input class="modal__input" name="name" value="{{name}}" required>
  |   <label class="modal__label">Description</label>
  |   <textarea class="modal__input issue-panel__edit-description" name="description">{{description}}</textarea>
  |   <div class="issue-panel__edit-row">
  |     <select class="mini-select" name="type">
  |       <option value="TASK" {{#if (eq type "TASK")}}selected{{/if}}>Task</option>
  |       <option value="BUG" {{#if (eq type "BUG")}}selected{{/if}}>Bug</option>
  |       <option value="STORY" {{#if (eq type "STORY")}}selected{{/if}}>Story</option>
  |     </select>
  |     <select class="mini-select" name="priority">
  |       <option value="IMMEDIATE" {{#if (eq priority "IMMEDIATE")}}selected{{/if}}>Immediate</option>
  |       <option value="HIGH" {{#if (eq priority "HIGH")}}selected{{/if}}>High</option>
  |       <option value="LOW" {{#if (eq priority "LOW")}}selected{{/if}}>Low</option>
  |     </select>
  |   </div>
  | </form>

script#tmpl-confirm-delete-issue(type="text/x-handlebars-template")
  | <div class="modal__form">
  |   <h2 class="modal__title">Delete {{ref}}?</h2>
  |   <p class="modal__hint">"{{name}}" will be removed permanently.</p>
  |   <div class="modal__actions">
  |     <button class="modal__btn modal__btn--cancel" type="button" data-dialog-close>Cancel</button>
  |     <button class="modal__btn modal__btn--submit" type="button"
  |             hx-delete="/api/v1/projects/{{projectSlug}}/issues/{{ref}}"
  |             hx-swap="none"
  |             data-dialog-close
  |             data-issue-deleted="{{ref}}">Delete</button>
  |   </div>
  | </div>

script#tmpl-confirm-delete-lane(type="text/x-handlebars-template")
  | <div class="modal__form">
  |   <h2 class="modal__title">Delete "{{laneName}}"?</h2>
  |   <p class="modal__hint">This will also remove the lane's issues.</p>
  |   <div class="modal__actions">
  |     <button class="modal__btn modal__btn--cancel" type="button" data-dialog-close>Cancel</button>
  |     <button class="modal__btn modal__btn--submit" type="button"
  |             hx-delete="/api/v1/projects/{{projectSlug}}/swimlanes/{{laneId}}"
  |             hx-swap="none"
  |             data-dialog-close>Delete</button>
  |   </div>
  | </div>
