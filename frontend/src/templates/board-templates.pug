script#tmpl-board(type="text/x-handlebars-template")
  | {{#each swimlanes}}
  |   <div class="lane" data-lane-id="{{id}}" data-lane-name="{{name}}">
  |     <div class="lane-header">
  |       <span class="lane-swatch" style="background:{{laneColor color}}"></span>
  |       <input class="lane-title" name="name" value="{{name}}" maxlength="40"
  |              hx-patch="/api/v1/projects/{{projectSlug}}/swimlanes/{{id}}"
  |              hx-trigger="blur changed"
  |              hx-ext="json-enc"
  |              hx-include="this"
  |              hx-swap="none">
  |       <span class="lane-count">{{issues.length}}</span>
  |       <button class="lane-menu" type="button" data-lane-menu="{{id}}" aria-label="Lane menu">⋯</button>
  |     </div>
  |     <div class="popover" data-lane-popover="{{id}}" hidden>
  |       <div class="popover__swatches">
  |         {{#each (laneColors)}}
  |           <button class="popover__swatch" type="button" style="background:{{this}}"
  |                   hx-patch="/api/v1/projects/{{projectSlug}}/swimlanes/{{../id}}"
  |                   hx-ext="json-enc"
  |                   hx-vals='{"color":"{{this}}"}'
  |                   hx-swap="none"></button>
  |         {{/each}}
  |       </div>
  |       <button class="popover__btn popover__danger" type="button"
  |               data-dialog-open="tmpl-confirm-delete-lane"
  |               data-dialog-data='{"laneId":{{id}},"laneName":"{{name}}"}'>
  |         Delete lane
  |       </button>
  |     </div>
  |     <div class="lane-body" data-lane-id="{{id}}">
  |       {{#if issues.length}}
  |         {{#each issues}}
  |           <div class="card" draggable="true" data-drag-kind="card" data-card-ref="{{ref}}" data-lane-id="{{swimlane_id}}"
  |                hx-get="/api/v1/projects/{{projectSlug}}/issues/{{ref}}"
  |                hx-target="#issuePanel"
  |                hx-trigger="click"
  |                hx-push-url="/board.html?project={{projectSlug}}&issue={{ref}}">
  |             <div class="card-strip" style="background:{{laneColor ../color}}"></div>
  |             <div class="card-top">
  |               <span class="card-id mono">{{ref}}</span>
  |               <span class="badge {{priorityClass priority}}">{{priority}}</span>
  |             </div>
  |             <div class="card-title">{{name}}</div>
  |             <div class="card-meta">
  |               <span class="tag tag-{{lower type}}">{{type}}</span>
  |             </div>
  |           </div>
  |         {{/each}}
  |       {{else}}
  |         <div class="lane-empty">No issues</div>
  |       {{/if}}
  |     </div>
  |     <div class="lane-footer">
  |       <button class="add-card-btn" type="button" data-lane-id="{{id}}">+ Add issue</button>
  |     </div>
  |   </div>
  | {{/each}}
  | <button class="add-lane" type="button"
  |         hx-post="/api/v1/projects/{{projectSlug}}/swimlanes"
  |         hx-ext="json-enc"
  |         hx-vals='{"name":"New lane"}'
  |         hx-swap="none">
  |   <span class="plus">+</span> Add lane
  | </button>

script#tmpl-add-issue-form(type="text/x-handlebars-template")
  | <form class="new-card-form"
  |       hx-post="/api/v1/projects/{{projectSlug}}/issues"
  |       hx-ext="json-enc"
  |       hx-swap="none">
  |   <input type="hidden" name="swimlane_id" value="{{laneId}}">
  |   <textarea class="new-card-form__textarea" name="name" placeholder="What needs doing?" required autofocus></textarea>
  |   <textarea class="new-card-form__textarea new-card-form__description" name="description" placeholder="Description (optional)"></textarea>
  |   <div class="new-card-form__row">
  |     <select class="mini-select" name="type">
  |       <option value="TASK" selected>Task</option>
  |       <option value="BUG">Bug</option>
  |       <option value="STORY">Story</option>
  |     </select>
  |     <select class="mini-select" name="priority">
  |       <option value="HIGH" selected>High</option>
  |       <option value="IMMEDIATE">Immediate</option>
  |       <option value="LOW">Low</option>
  |     </select>
  |     <span class="new-card-form__spacer"></span>
  |     <button type="submit" class="btn primary new-card-form__btn">Add</button>
  |     <button type="button" class="btn ghost new-card-form__btn" data-add-issue-cancel>Esc</button>
  |   </div>
  | </form>

script#tmpl-issue-panel(type="text/x-handlebars-template")
  | <div class="issue-panel__inner">
  |   <header class="issue-panel__header">
  |     <span class="issue-panel__ref mono">{{ref}}</span>
  |     <span class="badge {{priorityClass priority}}">{{priority}}</span>
  |     <span class="tag tag-{{lower type}}">{{type}}</span>
  |     <button type="button" class="issue-panel__close" data-issue-panel-close aria-label="Close">×</button>
  |   </header>
  |   <h2 class="issue-panel__title">{{name}}</h2>
  |   {{#if description}}
  |     <div class="issue-panel__description">{{description}}</div>
  |   {{/if}}
  | </div>

script#tmpl-confirm-delete-lane(type="text/x-handlebars-template")
  | <div class="modal__form">
  |   <h2 class="modal__title">Delete "{{laneName}}"?</h2>
  |   <p class="modal__hint">This will also remove the lane's issues.</p>
  |   <div class="modal__actions">
  |     <button class="modal__btn modal__btn--cancel" type="button" data-dialog-close>Cancel</button>
  |     <button class="modal__btn modal__btn--submit" type="button"
  |             hx-delete="/api/v1/projects/{{projectSlug}}/swimlanes/{{laneId}}"
  |             hx-swap="none"
  |             data-dialog-close>Delete</button>
  |   </div>
  | </div>
