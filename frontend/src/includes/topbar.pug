header.topbar
  a.brand(href='/')
    span.logo(aria-hidden='true')
      span.plate
      span.face Z
    span.brand-name Zdzira
  select.project-switcher#projectSwitcher(
    aria-label='Current project',
    hx-get='/api/v1/projects',
    hx-trigger='load',
    hx-ext='client-side-templates',
    handlebars-template='tmpl-project-options',
    hx-target='this',
    hx-swap='innerHTML'
  )
    option(value='', disabled, selected) Loading…
  .topbar-right
    button.btn.ghost(type='button', data-dialog-open='tmpl-new-project-form') + Project
    .mode-switch(role='tablist', aria-label='Color mode')
      button.mode-switch__btn(data-set='light', aria-pressed='true') Light
      button.mode-switch__btn(data-set='dark', aria-pressed='false') Dark
      button.mode-switch__btn(data-set='contrast', aria-pressed='false') Contrast
